{
  "break_timeout_sec": 90,
  "auto_archive_minutes": 5,
  "recent_done_minutes": 10,
  "extreme_stall_threshold_sec": 1200,

  "review_grace_periods": {
    "Menxia": 300,
    "Doing": 180,
    "Assigned": 120
  },

  "enabled_checks": {
    "illegal_flow": true,
    "skip_steps": true,
    "broken_chain": true,
    "cross_agent": true,
    "session_violation": true,
    "direct_execution": true,
    "extreme_stall": true
  },

  "max_notifications": 200,
  "max_violations": 200,
  "max_archived_violations": 500,
  "max_archived_notifications": 100,
  "wake_retry_enabled": true
}
